# ─────────────────────────────────────────────────────────────────────────────
#  Configuração do Terminal Web (gerenciador + Postgres).
#  Copie para .env e ajuste:  cp env.example .env
#  O gerenciador lê .env automaticamente (variáveis de ambiente têm prioridade).
# ─────────────────────────────────────────────────────────────────────────────

# --- Gerenciador (host) -------------------------------------------------------
# 0.0.0.0 = acessível na rede local | 127.0.0.1 = só nesta máquina.
MANAGER_HOST=0.0.0.0
MANAGER_PORT=8765

# Imagem do terminal (construída a partir do Containerfile).
IMAGE=web-terminal

# Chave para assinar cookies/sessão. OBRIGATÓRIA em produção.
# Gere com:  python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Marque os cookies como Secure (use só quando servir por HTTPS).
FORCE_HTTPS=false

# Permitir que novos usuários se cadastrem na tela de login (true/false).
ALLOW_REGISTER=true

# Conta criada automaticamente na primeira execução (opcional).
# Deixe em branco para não criar nenhuma.
ADMIN_USER=admin
ADMIN_PASSWORD=troque-esta-senha-admin

# --- PostgreSQL (container separado) ------------------------------------------
PG_CONTAINER=web-terminal-db
PG_IMAGE=docker.io/library/postgres:16-alpine
PG_USER=webterminal
PG_PASSWORD=troque-esta-senha-do-banco
PG_DB=webterminal
# Porta publicada no host (apenas em 127.0.0.1).
PG_PORT=5432
# Volume nomeado onde os dados do Postgres persistem.
PG_VOLUME=web-terminal-pgdata
